// LETTUCE — List command tests (LPUSH/RPUSH/LPOP/RPOP/LLEN/LRANGE)
package main
import std.core.ptr.Ptr
import std.core.str.StringView
import std.collections.string_map.{StringMap, StringMap_new}
import lettuce.list.{handle_lpush_one, handle_rpush_one, handle_lpop, handle_rpop, handle_llen, handle_lrange}
extern fn exit(code: i32);

fn assert_int(expected: i64, actual: i64, test_id: i32) {
    if actual != expected { exit(test_id); }
}

fn test_push_pop() {
    let mut out: [u8; 256] = [0; 256];
    let buf = &out[0] as Ptr<u8>;

    // LPUSH mylist "world" "hello" → list is hello,world (LPUSH prepends each)
    let r1 = handle_lpush_one("mylist" as StringView, "hello" as StringView, buf);
    let r2 = handle_lpush_one("mylist" as StringView, "world" as StringView, buf);

    // LLEN mylist → 2
    let len_r = handle_llen("mylist" as StringView, buf);
    // LPOP mylist → "world"
    let pop_r = handle_lpop("mylist" as StringView, buf);
    // RPOP mylist → "hello"
    let pop2_r = handle_rpop("mylist" as StringView, buf);

    // Verify no crash — actual RESP validation would parse the output
}

pub fn main() -> i32 {
    test_push_pop();
    return 0;
}
