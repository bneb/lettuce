// =============================================================================
// LETTUCE — Data Store Tests (TDD)
// =============================================================================
// Tests the StringMap SwissTable from stdlib: SET, GET, DEL, overwrite,
// multiple keys, compacting rehash.
//
// Run: ./scripts/run_test.sh lettuce/tests/test_store.salt
// =============================================================================

package main

import std.core.ptr.Ptr
import std.core.str.StringView
import std.collections.string_map.StringMap
import std.collections.string_map.fnv1a
import std.collections.string_map.{StringMap_new, StringMap_with_capacity, StringMap_get, StringMap_value_at, StringMap_set, StringMap_del, StringMap_length, StringMap_is_empty, StringMap_drop}

extern fn exit(code: i32);
extern fn memcpy(dst: Ptr<u8>, src: Ptr<u8>, n: i64) -> Ptr<u8>;

// Dummy for linker when testing store.salt standalone
pub fn ebr_retire(core: u64, ptr: u64) {}

// ============================================================================
// Test Helpers
// ============================================================================
fn assert_true(cond: bool, test_id: i32) {
    if !cond {
        println(f"FAIL test {test_id}");
        exit(test_id);
    }
}

fn assert_eq(got: i64, expected: i64, test_id: i32) {
    if got != expected {
        println(f"FAIL test {test_id}: got {got}, expected {expected}");
        exit(test_id);
    }
}

// ============================================================================
// Tests
// ============================================================================
fn test_fnv_hash() {
    let h1 = fnv1a("foo" as StringView);
    let h2 = fnv1a("foo" as StringView);
    assert_eq(h1 as i64, h2 as i64, 1);
    let h3 = fnv1a("bar" as StringView);
    assert_true(h1 != h3, 1);
    println("PASS test_fnv_hash");
}

fn test_basic_operations() {
    let mut smap = StringMap_new();
    StringMap_set(smap, "foo" as StringView, "bar" as StringView);
    let slot = StringMap_get(smap, "foo" as StringView);
    assert_true(slot >= 0, 2);
    let val = StringMap_value_at(smap, slot);
    assert_eq(val.length(), 3, 2);
    assert_eq(val.byte_at(0) as i64, 98, 2);   // 'b'
    assert_eq(val.byte_at(1) as i64, 97, 2);   // 'a'
    assert_eq(val.byte_at(2) as i64, 114, 2);  // 'r'
    println("PASS test_set_get");

    let slot3 = StringMap_get(smap, "nonexistent" as StringView);
    assert_eq(slot3, -1, 3);
    println("PASS test_get_unknown");

    let deleted = StringMap_del(smap, "foo" as StringView);
    assert_true(deleted, 4);
    let slot4 = StringMap_get(smap, "foo" as StringView);
    assert_eq(slot4, -1, 4);
    println("PASS test_del_existing");

    let del5 = StringMap_del(smap, "ghost" as StringView);
    assert_true(!del5, 5);
    println("PASS test_del_unknown");

    StringMap_set(smap, "mykey" as StringView, "oldval" as StringView);
    StringMap_set(smap, "mykey" as StringView, "newval" as StringView);
    let slot6 = StringMap_get(smap, "mykey" as StringView);
    assert_true(slot6 >= 0, 6);
    let val6 = StringMap_value_at(smap, slot6);
    assert_eq(val6.length(), 6, 6);
    assert_eq(val6.byte_at(0) as i64, 110, 6);  // 'n'
    assert_eq(val6.byte_at(3) as i64, 118, 6);  // 'v'
    println("PASS test_set_overwrite");

    StringMap_set(smap, "alpha" as StringView, "AAA" as StringView);
    StringMap_set(smap, "beta" as StringView, "BBB" as StringView);
    StringMap_set(smap, "gamma" as StringView, "CCC" as StringView);

    let sa = StringMap_get(smap, "alpha" as StringView);
    assert_true(sa >= 0, 7);
    assert_eq(StringMap_value_at(smap, sa).length(), 3, 7);
    let sb = StringMap_get(smap, "beta" as StringView);
    assert_true(sb >= 0, 7);
    let sg = StringMap_get(smap, "gamma" as StringView);
    assert_true(sg >= 0, 7);
    println("PASS test_multiple_keys");
    StringMap_drop(smap);
}

fn test_compacting_rehash() {
    let mut smap = StringMap_with_capacity(16);
    let mut i: i64 = 0;
    while i < 15 {
        let mut kb: [u8; 4] = [0; 4];
        kb[0] = 107;  // 'k'
        kb[1] = ((i / 10) + 48) as u8;
        kb[2] = ((i % 10) + 48) as u8;
        let key = StringView::from_raw(&kb[0] as Ptr<u8>, 3);

        let mut vb: [u8; 4] = [0; 4];
        vb[0] = 118;  // 'v'
        vb[1] = ((i / 10) + 48) as u8;
        vb[2] = ((i % 10) + 48) as u8;
        let val = StringView::from_raw(&vb[0] as Ptr<u8>, 3);

        StringMap_set(smap, key, val);
        i = i + 1;
    }

    let mut kb0: [u8; 4] = [0; 4];
    kb0[0] = 107; kb0[1] = 48; kb0[2] = 48;
    let s8a = StringMap_get(smap, StringView::from_raw(&kb0[0] as Ptr<u8>, 3));
    assert_true(s8a >= 0, 8);
    assert_eq(StringMap_value_at(smap, s8a).length(), 3, 8);

    let mut kb14: [u8; 4] = [0; 4];
    kb14[0] = 107; kb14[1] = 49; kb14[2] = 52;
    let s8b = StringMap_get(smap, StringView::from_raw(&kb14[0] as Ptr<u8>, 3));
    assert_true(s8b >= 0, 8);

    assert_eq(StringMap_length(smap), 15, 8);
    assert_true(StringMap_is_empty(smap) == false, 8);
    println("PASS test_compacting_rehash");

    StringMap_drop(smap);
}

fn main() -> i32 {
    println("=== LETTUCE StringMap Tests ===");
    test_fnv_hash();
    test_basic_operations();
    test_compacting_rehash();
    println("=== All StringMap tests passed ===");
    return 0;
}
