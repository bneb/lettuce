// =============================================================================
// LETTUCE — RESP Protocol Parser Tests (TDD)
// =============================================================================
// Tests the Redis Serialization Protocol parser against all RESP types:
//   +  Simple Strings
//   -  Errors
//   :  Integers
//   $  Bulk Strings (including null: $-1)
//   *  Arrays
//
// Run: ./scripts/run_test.sh lettuce/tests/test_resp.salt
// =============================================================================

package main

import std.core.ptr.Ptr
import std.core.str.StringView

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);
extern fn exit(code: i32);
extern fn memcpy(dst: Ptr<u8>, src: Ptr<u8>, n: i64) -> Ptr<u8>;

// ============================================================================
// RESP Type Constants
// ============================================================================
const RESP_SIMPLE_STRING: i64 = 1;
const RESP_ERROR: i64 = 2;
const RESP_INTEGER: i64 = 3;
const RESP_BULK_STRING: i64 = 4;
const RESP_ARRAY: i64 = 5;
const RESP_NULL: i64 = 6;

// ============================================================================
// RespValue — Flat tagged struct for parsed RESP data
// ============================================================================
struct RespValue {
    type_tag: i64,
    int_val: i64,
    str_ptr: Ptr<u8>,
    str_len: i64,
    array_count: i64,
    bytes_consumed: i64,
}

fn resp_nil() -> RespValue {
    return RespValue {
        type_tag: RESP_NULL,
        int_val: 0,
        str_ptr: 0 as Ptr<u8>,
        str_len: 0,
        array_count: 0,
        bytes_consumed: 0,
    };
}

// ============================================================================
// Helper: find \r\n in a StringView starting from offset
// Returns index of \r, or -1 if not found
// ============================================================================
fn find_crlf(input: StringView, start: i64) -> i64 {
    let len = input.length();
    let mut i = start;
    while i < len - 1 {
        if input.byte_at(i) == 13 && input.byte_at(i + 1) == 10 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

// ============================================================================
// Helper: parse ASCII integer from StringView[start..end)
// Handles negative numbers
// ============================================================================
fn parse_int_from_view(input: StringView, start: i64, end: i64) -> i64 {
    let mut result: i64 = 0;
    let mut neg: bool = false;
    let mut i = start;

    if i < end && input.byte_at(i) == 45 {
        neg = true;
        i = i + 1;
    }

    while i < end {
        let b = input.byte_at(i) as i64;
        result = result * 10 + (b - 48);
        i = i + 1;
    }

    if neg {
        return 0 - result;
    }
    return result;
}

// ============================================================================
// RespParser: parse a single RESP value from a StringView
// ============================================================================
fn parse_resp_simple_string(input: StringView, crlf: i64) -> RespValue {
    let sv = input.slice(1, crlf);
    return RespValue {
        type_tag: RESP_SIMPLE_STRING,
        int_val: 0,
        str_ptr: sv.ptr,
        str_len: sv.length(),
        array_count: 0,
        bytes_consumed: crlf + 2,
    };
}

fn parse_resp_error(input: StringView, crlf: i64) -> RespValue {
    let sv = input.slice(1, crlf);
    return RespValue {
        type_tag: RESP_ERROR,
        int_val: 0,
        str_ptr: sv.ptr,
        str_len: sv.length(),
        array_count: 0,
        bytes_consumed: crlf + 2,
    };
}

fn parse_resp_integer(input: StringView, crlf: i64) -> RespValue {
    let val = parse_int_from_view(input, 1, crlf);
    return RespValue {
        type_tag: RESP_INTEGER,
        int_val: val,
        str_ptr: 0 as Ptr<u8>,
        str_len: 0,
        array_count: 0,
        bytes_consumed: crlf + 2,
    };
}

fn parse_resp_bulk_string(input: StringView, crlf: i64) -> RespValue {
    let str_len = parse_int_from_view(input, 1, crlf);

    if str_len < 0 {
        return RespValue {
            type_tag: RESP_NULL,
            int_val: 0,
            str_ptr: 0 as Ptr<u8>,
            str_len: 0,
            array_count: 0,
            bytes_consumed: crlf + 2,
        };
    }

    let data_start = crlf + 2;
    let data_end = data_start + str_len;
    let sv = input.slice(data_start, data_end);
    return RespValue {
        type_tag: RESP_BULK_STRING,
        int_val: 0,
        str_ptr: sv.ptr,
        str_len: sv.length(),
        array_count: 0,
        bytes_consumed: data_end + 2,
    };
}

fn parse_resp_array(input: StringView, crlf: i64, len: i64) -> RespValue {
    let count = parse_int_from_view(input, 1, crlf);

    if count < 0 {
        return RespValue {
            type_tag: RESP_NULL,
            int_val: 0,
            str_ptr: 0 as Ptr<u8>,
            str_len: 0,
            array_count: 0,
            bytes_consumed: crlf + 2,
        };
    }

    let mut offset = crlf + 2;
    let mut i: i64 = 0;
    while i < count {
        let remaining = input.slice(offset, len);
        let elem = resp_parse(remaining);
        offset = offset + elem.bytes_consumed;
        i = i + 1;
    }

    let elems_start = crlf + 2;
    return RespValue {
        type_tag: RESP_ARRAY,
        int_val: 0,
        str_ptr: input.slice(elems_start, offset).ptr,
        str_len: offset - elems_start,
        array_count: count,
        bytes_consumed: offset,
    };
}

fn resp_parse(input: StringView) -> RespValue {
    let len = input.length();
    if len == 0 {
        return resp_nil();
    }

    let prefix = input.byte_at(0);
    let crlf = find_crlf(input, 1);
    if crlf < 0 {
        return resp_nil();
    }

    if prefix == 43 {
        return parse_resp_simple_string(input, crlf);
    }
    if prefix == 45 {
        return parse_resp_error(input, crlf);
    }
    if prefix == 58 {
        return parse_resp_integer(input, crlf);
    }
    if prefix == 36 {
        return parse_resp_bulk_string(input, crlf);
    }
    if prefix == 42 {
        return parse_resp_array(input, crlf, len);
    }

    return resp_nil();
}

// ============================================================================
// RespWriter: format RESP responses into a buffer
// Returns bytes written
// ============================================================================

// Helper: write i64 as ASCII decimal digits to buf. Returns bytes written.
fn write_i64_to_buf(buf: Ptr<u8>, val: i64) -> i64 {
    if val == 0 {
        buf.write(48);
        return 1;
    }

    let mut v = val;
    let mut neg = false;
    if v < 0 {
        neg = true;
        v = 0 - v;
    }

    // Write digits in reverse into temp buffer
    let mut tmp: [u8; 20] = [0; 20];
    let mut count: i64 = 0;
    while v > 0 {
        tmp[count] = ((v % 10) + 48) as u8;
        v = v / 10;
        count = count + 1;
    }

    let mut pos: i64 = 0;
    if neg {
        buf.write(45);  // '-'
        pos = 1;
    }

    // Reverse copy
    let mut i = count - 1;
    while i >= 0 {
        buf.offset(pos).write(tmp[i]);
        pos = pos + 1;
        i = i - 1;
    }

    return pos;
}

fn write_simple_string(buf: Ptr<u8>, msg: StringView) -> i64 {
    buf.write(43);  // '+'
    memcpy(buf.offset(1), msg.ptr, msg.length());
    buf.offset(1 + msg.length()).write(13);      // '\r'
    buf.offset(1 + msg.length() + 1).write(10);  // '\n'
    return 1 + msg.length() + 2;
}

fn write_error(buf: Ptr<u8>, msg: StringView) -> i64 {
    buf.write(45);  // '-'
    memcpy(buf.offset(1), msg.ptr, msg.length());
    buf.offset(1 + msg.length()).write(13);
    buf.offset(1 + msg.length() + 1).write(10);
    return 1 + msg.length() + 2;
}

fn write_integer(buf: Ptr<u8>, val: i64) -> i64 {
    buf.write(58);  // ':'
    let num_len = write_i64_to_buf(buf.offset(1), val);
    buf.offset(1 + num_len).write(13);
    buf.offset(1 + num_len + 1).write(10);
    return 1 + num_len + 2;
}

fn write_bulk_string(buf: Ptr<u8>, data: StringView) -> i64 {
    buf.write(36);  // '$'
    let len_str = write_i64_to_buf(buf.offset(1), data.length());
    let mut pos = 1 + len_str;
    buf.offset(pos).write(13);
    buf.offset(pos + 1).write(10);
    pos = pos + 2;
    memcpy(buf.offset(pos), data.ptr, data.length());
    pos = pos + data.length();
    buf.offset(pos).write(13);
    buf.offset(pos + 1).write(10);
    return pos + 2;
}

fn write_null_bulk(buf: Ptr<u8>) -> i64 {
    // $-1\r\n
    buf.write(36);           // '$'
    buf.offset(1).write(45); // '-'
    buf.offset(2).write(49); // '1'
    buf.offset(3).write(13); // '\r'
    buf.offset(4).write(10); // '\n'
    return 5;
}

// ============================================================================
// Test Helpers
// ============================================================================
fn assert_true(cond: bool, test_id: i32) {
    if !cond {
        println(f"FAIL test {test_id}");
        exit(test_id);
    }
}

fn assert_eq(got: i64, expected: i64, test_id: i32) {
    if got != expected {
        println(f"FAIL test {test_id}: got {got}, expected {expected}");
        exit(test_id);
    }
}

// ============================================================================
// Tests
// ============================================================================

fn test_parse_simple_string() {
    // "+OK\r\n" = [43, 79, 75, 13, 10]
    let mut buf: [u8; 16] = [0; 16];
    buf[0] = 43;  // '+'
    buf[1] = 79;  // 'O'
    buf[2] = 75;  // 'K'
    buf[3] = 13;  // '\r'
    buf[4] = 10;  // '\n'
    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 5);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_SIMPLE_STRING, 1);
    assert_eq(val.str_len, 2, 1);
    assert_eq(val.bytes_consumed, 5, 1);

    // Check the string content is "OK"
    let sv = StringView::from_raw(val.str_ptr, val.str_len);
    assert_eq(sv.byte_at(0) as i64, 79, 1);  // 'O'
    assert_eq(sv.byte_at(1) as i64, 75, 1);  // 'K'

    println("PASS test_parse_simple_string");
}

fn test_parse_error() {
    // "-ERR unknown\r\n"
    let mut buf: [u8; 32] = [0; 32];
    buf[0] = 45;   // '-'
    buf[1] = 69;   // 'E'
    buf[2] = 82;   // 'R'
    buf[3] = 82;   // 'R'
    buf[4] = 32;   // ' '
    buf[5] = 117;  // 'u'
    buf[6] = 110;  // 'n'
    buf[7] = 107;  // 'k'
    buf[8] = 110;  // 'n'
    buf[9] = 111;  // 'o'
    buf[10] = 119; // 'w'
    buf[11] = 110; // 'n'
    buf[12] = 13;  // '\r'
    buf[13] = 10;  // '\n'
    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 14);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_ERROR, 2);
    assert_eq(val.str_len, 11, 2);  // "ERR unknown" = 11 bytes
    assert_eq(val.bytes_consumed, 14, 2);
    println("PASS test_parse_error");
}

fn test_parse_integer() {
    // ":1000\r\n"
    let mut buf: [u8; 16] = [0; 16];
    buf[0] = 58;  // ':'
    buf[1] = 49;  // '1'
    buf[2] = 48;  // '0'
    buf[3] = 48;  // '0'
    buf[4] = 48;  // '0'
    buf[5] = 13;  // '\r'
    buf[6] = 10;  // '\n'
    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 7);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_INTEGER, 3);
    assert_eq(val.int_val, 1000, 3);
    assert_eq(val.bytes_consumed, 7, 3);
    println("PASS test_parse_integer");
}

fn test_parse_negative_integer() {
    // ":-42\r\n"
    let mut buf: [u8; 16] = [0; 16];
    buf[0] = 58;  // ':'
    buf[1] = 45;  // '-'
    buf[2] = 52;  // '4'
    buf[3] = 50;  // '2'
    buf[4] = 13;  // '\r'
    buf[5] = 10;  // '\n'
    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 6);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_INTEGER, 4);
    assert_eq(val.int_val, -42, 4);
    assert_eq(val.bytes_consumed, 6, 4);
    println("PASS test_parse_negative_integer");
}

fn test_parse_bulk_string() {
    // "$6\r\nfoobar\r\n"
    let mut buf: [u8; 32] = [0; 32];
    buf[0] = 36;   // '$'
    buf[1] = 54;   // '6'
    buf[2] = 13;   // '\r'
    buf[3] = 10;   // '\n'
    buf[4] = 102;  // 'f'
    buf[5] = 111;  // 'o'
    buf[6] = 111;  // 'o'
    buf[7] = 98;   // 'b'
    buf[8] = 97;   // 'a'
    buf[9] = 114;  // 'r'
    buf[10] = 13;  // '\r'
    buf[11] = 10;  // '\n'
    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 12);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_BULK_STRING, 5);
    assert_eq(val.str_len, 6, 5);
    assert_eq(val.bytes_consumed, 12, 5);

    let sv = StringView::from_raw(val.str_ptr, val.str_len);
    assert_eq(sv.byte_at(0) as i64, 102, 5);  // 'f'
    assert_eq(sv.byte_at(5) as i64, 114, 5);  // 'r'
    println("PASS test_parse_bulk_string");
}

fn test_parse_null_bulk_string() {
    // "$-1\r\n"
    let mut buf: [u8; 16] = [0; 16];
    buf[0] = 36;  // '$'
    buf[1] = 45;  // '-'
    buf[2] = 49;  // '1'
    buf[3] = 13;  // '\r'
    buf[4] = 10;  // '\n'
    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 5);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_NULL, 6);
    assert_eq(val.bytes_consumed, 5, 6);
    println("PASS test_parse_null_bulk_string");
}

fn test_parse_array() {
    // "*2\r\n$4\r\nLLEN\r\n$6\r\nmylist\r\n"
    let mut buf: [u8; 64] = [0; 64];
    // *2\r\n
    buf[0] = 42;   // '*'
    buf[1] = 50;   // '2'
    buf[2] = 13;   // '\r'
    buf[3] = 10;   // '\n'
    // $4\r\nLLEN\r\n
    buf[4] = 36;   // '$'
    buf[5] = 52;   // '4'
    buf[6] = 13;   // '\r'
    buf[7] = 10;   // '\n'
    buf[8] = 76;   // 'L'
    buf[9] = 76;   // 'L'
    buf[10] = 69;  // 'E'
    buf[11] = 78;  // 'N'
    buf[12] = 13;  // '\r'
    buf[13] = 10;  // '\n'
    // $6\r\nmylist\r\n
    buf[14] = 36;  // '$'
    buf[15] = 54;  // '6'
    buf[16] = 13;  // '\r'
    buf[17] = 10;  // '\n'
    buf[18] = 109; // 'm'
    buf[19] = 121; // 'y'
    buf[20] = 108; // 'l'
    buf[21] = 105; // 'i'
    buf[22] = 115; // 's'
    buf[23] = 116; // 't'
    buf[24] = 13;  // '\r'
    buf[25] = 10;  // '\n'

    let input = StringView::from_raw(&buf[0] as Ptr<u8>, 26);
    let val = resp_parse(input);

    assert_eq(val.type_tag, RESP_ARRAY, 7);
    assert_eq(val.array_count, 2, 7);
    assert_eq(val.bytes_consumed, 26, 7);

    // Parse individual elements from array data
    let elems_view = StringView::from_raw(val.str_ptr, val.str_len);
    let elem1 = resp_parse(elems_view);
    assert_eq(elem1.type_tag, RESP_BULK_STRING, 7);
    assert_eq(elem1.str_len, 4, 7);  // "LLEN"

    let remaining = elems_view.slice(elem1.bytes_consumed, elems_view.length());
    let elem2 = resp_parse(remaining);
    assert_eq(elem2.type_tag, RESP_BULK_STRING, 7);
    assert_eq(elem2.str_len, 6, 7);  // "mylist"

    println("PASS test_parse_array");
}

fn test_write_simple_string() {
    let buf = malloc(256);
    let msg = "OK" as StringView;
    let n = write_simple_string(buf, msg);

    assert_eq(n, 5, 8);                        // "+OK\r\n"
    assert_eq(buf.read() as i64, 43, 8);       // '+'
    assert_eq(buf.offset(1).read() as i64, 79, 8);  // 'O'
    assert_eq(buf.offset(2).read() as i64, 75, 8);  // 'K'
    assert_eq(buf.offset(3).read() as i64, 13, 8);  // '\r'
    assert_eq(buf.offset(4).read() as i64, 10, 8);  // '\n'

    free(buf);
    println("PASS test_write_simple_string");
}

fn test_write_error() {
    let buf = malloc(256);
    let msg = "ERR bad command" as StringView;
    let n = write_error(buf, msg);

    assert_eq(buf.read() as i64, 45, 9);  // '-'
    assert_true(n > 0, 9);

    free(buf);
    println("PASS test_write_error");
}

fn test_write_integer() {
    let buf = malloc(256);
    let n = write_integer(buf, 1000);

    assert_eq(buf.read() as i64, 58, 10);  // ':'
    assert_true(n > 0, 10);

    // Parse it back
    let input = StringView::from_raw(buf, n);
    let val = resp_parse(input);
    assert_eq(val.type_tag, RESP_INTEGER, 10);
    assert_eq(val.int_val, 1000, 10);

    free(buf);
    println("PASS test_write_integer");
}

fn test_write_bulk_string() {
    let buf = malloc(256);
    let data = "foobar" as StringView;
    let n = write_bulk_string(buf, data);

    assert_eq(buf.read() as i64, 36, 11);  // '$'
    assert_true(n > 0, 11);

    // Parse it back
    let input = StringView::from_raw(buf, n);
    let val = resp_parse(input);
    assert_eq(val.type_tag, RESP_BULK_STRING, 11);
    assert_eq(val.str_len, 6, 11);

    free(buf);
    println("PASS test_write_bulk_string");
}

fn test_write_null() {
    let buf = malloc(256);
    let n = write_null_bulk(buf);

    assert_eq(n, 5, 12);  // "$-1\r\n"

    let input = StringView::from_raw(buf, n);
    let val = resp_parse(input);
    assert_eq(val.type_tag, RESP_NULL, 12);

    free(buf);
    println("PASS test_write_null");
}

fn test_write_i64_zero() {
    let buf = malloc(256);
    let n = write_i64_to_buf(buf, 0);
    assert_eq(n, 1, 13);
    assert_eq(buf.read() as i64, 48, 13);  // '0'
    free(buf);
    println("PASS test_write_i64_zero");
}

fn test_write_i64_negative() {
    let buf = malloc(256);
    let n = write_i64_to_buf(buf, -1);
    assert_eq(n, 2, 14);
    assert_eq(buf.read() as i64, 45, 14);        // '-'
    assert_eq(buf.offset(1).read() as i64, 49, 14); // '1'
    free(buf);
    println("PASS test_write_i64_negative");
}

fn test_roundtrip_bulk_string() {
    // Write a bulk string, then parse it back
    let buf = malloc(256);
    let original = "Hello, LETTUCE!" as StringView;
    let n = write_bulk_string(buf, original);

    let input = StringView::from_raw(buf, n);
    let parsed = resp_parse(input);

    assert_eq(parsed.type_tag, RESP_BULK_STRING, 15);
    assert_eq(parsed.str_len, 15, 15);

    // Verify content byte by byte
    let sv = StringView::from_raw(parsed.str_ptr, parsed.str_len);
    assert_eq(sv.byte_at(0) as i64, 72, 15);   // 'H'
    assert_eq(sv.byte_at(14) as i64, 33, 15);  // '!'

    free(buf);
    println("PASS test_roundtrip_bulk_string");
}

// ============================================================================
// Main
// ============================================================================
fn main() -> i32 {
    println("=== LETTUCE RESP Parser Tests ===");

    test_parse_simple_string();
    test_parse_error();
    test_parse_integer();
    test_parse_negative_integer();
    test_parse_bulk_string();
    test_parse_null_bulk_string();
    test_parse_array();
    test_write_simple_string();
    test_write_error();
    test_write_integer();
    test_write_bulk_string();
    test_write_null();
    test_write_i64_zero();
    test_write_i64_negative();
    test_roundtrip_bulk_string();

    println("=== All RESP tests passed ===");
    return 0;
}
