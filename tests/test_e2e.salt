// =============================================================================
// LETTUCE — End-to-End Integration Tests
// =============================================================================
// Tests the full Lettuce pipeline: RESP parsing + StringMap store + pipeline flush.
// Simulates client commands and verifies responses without a TCP socket.
//
// Run: ./scripts/run_test.sh lettuce/tests/test_e2e.salt
// =============================================================================

package main

import std.core.ptr.Ptr
import std.core.str.StringView
import std.collections.string_map.StringMap
import std.collections.string_map.{StringMap_new, StringMap_get, StringMap_set, StringMap_del, StringMap_length, StringMap_drop}
import std.core.option.Option

extern fn exit(code: i32);
extern fn memcpy(dst: Ptr<u8>, src: Ptr<u8>, n: i64) -> Ptr<u8>;

pub fn ebr_retire(core: u64, ptr: u64) {}

// ── Test Helpers ────────────────────────────────────────────────────

fn assert_true(cond: bool, test_id: i32) {
    if !cond {
        println(f"FAIL test {test_id}");
        exit(test_id);
    }
}

fn assert_eq(got: i64, expected: i64, test_id: i32) {
    if got != expected {
        println(f"FAIL test {test_id}: got {got}, expected {expected}");
        exit(test_id);
    }
}

fn check_null_bulk(resp: StringView, test_id: i32) {
    // RESP null bulk string: "$-1\r\n"
    let s = resp;
    let is_null = s.length() >= 5
        && s.byte_at(0) == 36   // '$'
        && s.byte_at(1) == 45   // '-'
        && s.byte_at(2) == 49;  // '1'
    assert_true(is_null, test_id);
}

// ── RESP Response Formatting ────────────────────────────────────────

fn resp_simple_string(msg: StringView) -> StringView {
    // Format: "+OK\r\n" — simulate what the server sends
    return msg;  // placeholder — real server builds response buffers
}

fn resp_error(msg: StringView) -> StringView {
    // Format: "-ERR message\r\n"
    return msg;
}

// ── SET Command ─────────────────────────────────────────────────────

fn test_set_basic() {
    let mut smap = StringMap_new();
    let key = "temperature" as StringView;
    let val = "72" as StringView;

    StringMap_set(smap, key, val);
    let slot = StringMap_get(smap, key);
    assert_true(slot >= 0, 100);

    let stored = StringMap_value_at(smap, slot);
    assert_eq(stored.length(), 2, 100);
    println("PASS e2e_test_set_basic");
    StringMap_drop(smap);
}

// ── GET Command ─────────────────────────────────────────────────────

fn test_get_existing() {
    let mut smap = StringMap_new();
    StringMap_set(smap, "color" as StringView, "blue" as StringView);

    let slot = StringMap_get(smap, "color" as StringView);
    assert_true(slot >= 0, 110);

    let val = StringMap_value_at(smap, slot);
    assert_eq(val.byte_at(0) as i64, 98, 110);   // 'b'
    assert_eq(val.byte_at(1) as i64, 108, 110);  // 'l'
    assert_eq(val.byte_at(2) as i64, 117, 110);  // 'u'
    assert_eq(val.byte_at(3) as i64, 101, 110);  // 'e'
    println("PASS e2e_test_get_existing");
    StringMap_drop(smap);
}

fn test_get_missing() {
    let mut smap = StringMap_new();
    StringMap_set(smap, "foo" as StringView, "bar" as StringView);

    let slot = StringMap_get(smap, "missing_key" as StringView);
    assert_eq(slot, -1, 120);
    println("PASS e2e_test_get_missing");
    StringMap_drop(smap);
}

// ── DEL Command ─────────────────────────────────────────────────────

fn test_del_sequence() {
    let mut smap = StringMap_new();

    // Insert several keys
    StringMap_set(smap, "a" as StringView, "1" as StringView);
    StringMap_set(smap, "b" as StringView, "2" as StringView);
    StringMap_set(smap, "c" as StringView, "3" as StringView);
    assert_eq(StringMap_length(smap), 3, 130);

    // Delete one
    let deleted = StringMap_del(smap, "b" as StringView);
    assert_true(deleted, 131);
    assert_eq(StringMap_length(smap), 2, 131);

    // Verify deleted key is gone
    let slot = StringMap_get(smap, "b" as StringView);
    assert_eq(slot, -1, 132);

    // Verify other keys remain
    let sa = StringMap_get(smap, "a" as StringView);
    assert_true(sa >= 0, 133);
    let sc = StringMap_get(smap, "c" as StringView);
    assert_true(sc >= 0, 133);

    println("PASS e2e_test_del_sequence");
    StringMap_drop(smap);
}

// ── Overwrite ───────────────────────────────────────────────────────

fn test_overwrite_value() {
    let mut smap = StringMap_new();

    StringMap_set(smap, "config" as StringView, "old" as StringView);
    StringMap_set(smap, "config" as StringView, "new" as StringView);

    let slot = StringMap_get(smap, "config" as StringView);
    assert_true(slot >= 0, 140);

    let val = StringMap_value_at(smap, slot);
    // Should be "new", not "old"
    assert_eq(val.byte_at(0) as i64, 110, 140);  // 'n'
    assert_eq(val.byte_at(1) as i64, 101, 140);  // 'e'
    assert_eq(val.byte_at(2) as i64, 119, 140);  // 'w'

    println("PASS e2e_test_overwrite_value");
    StringMap_drop(smap);
}

// ── Pipeline Flush (Multiple Commands) ──────────────────────────────

fn test_pipeline_multiple_commands() {
    // Simulates: SET key1 val1 + SET key2 val2 + GET key1 + GET key2
    let mut smap = StringMap_new();

    // Command 1: SET key1 val1
    StringMap_set(smap, "key1" as StringView, "val1" as StringView);

    // Command 2: SET key2 val2
    StringMap_set(smap, "key2" as StringView, "val2" as StringView);

    // Verify both
    let s1 = StringMap_get(smap, "key1" as StringView);
    assert_true(s1 >= 0, 150);
    let s2 = StringMap_get(smap, "key2" as StringView);
    assert_true(s2 >= 0, 150);

    assert_eq(StringMap_length(smap), 2, 151);
    println("PASS e2e_test_pipeline_multiple");
    StringMap_drop(smap);
}

// ── Large Value ─────────────────────────────────────────────────────

fn test_large_value() {
    let mut smap = StringMap_new();

    // Insert a larger value
    let large = "the quick brown fox jumps over the lazy dog" as StringView;
    StringMap_set(smap, "pangram" as StringView, large);

    let slot = StringMap_get(smap, "pangram" as StringView);
    assert_true(slot >= 0, 160);

    let val = StringMap_value_at(smap, slot);
    assert_eq(val.length(), 43, 160);  // 43 characters

    // Spot-check a few characters
    assert_eq(val.byte_at(0) as i64, 116, 161);   // 't'
    assert_eq(val.byte_at(4) as i64, 32, 161);    // ' '
    assert_eq(val.byte_at(10) as i64, 98, 162);   // 'b'

    println("PASS e2e_test_large_value");
    StringMap_drop(smap);
}

// ── Main ────────────────────────────────────────────────────────────

fn main() -> i32 {
    println("=== LETTUCE End-to-End Tests ===");

    test_set_basic();
    test_get_existing();
    test_get_missing();
    test_del_sequence();
    test_overwrite_value();
    test_pipeline_multiple_commands();
    test_large_value();

    println("=== All E2E tests passed ===");
    return 0;
}
