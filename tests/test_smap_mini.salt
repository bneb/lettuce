package main

import std.core.ptr.Ptr
import std.core.str.StringView
import std.collections.string_map.StringMap
import std.collections.string_map.fnv1a

fn main() -> i32 {
    println("=== StringMap Mini Test ===");
    
    let mut smap = StringMap::new();
    println("PASS new()");
    
    smap.set("foo" as StringView, "bar" as StringView);
    println("PASS set(foo, bar)");
    
    let slot = smap.get("foo" as StringView);
    if slot < 0 {
        println("FAIL get(foo) returned -1");
        return 1;
    }
    
    let val = smap.value_at(slot);
    if val.length() != 3 {
        println("FAIL val.length != 3");
        return 1;
    }
    println("PASS get(foo) + value_at");
    
    smap.drop();
    println("ALL PASS");
    return 0;
}
